import aes_pkg::*;

module keyExpansion(
    input  logic [7:0] key[0:3][0:3],
    output logic [127:0] roundKey [0:10]  // all 11 keys ready at once
);
    logic [31:0] W [0:43];  // all 44 words
    logic [31:0] rotTemp;
    logic [31:0] subTemp;
    logic [31:0] gTemp;


    logic [31:0] RCi[9:0];
    always_comb begin : blockName
        RCi[0] = {8'h01 , 24'b0};        
        RCi[1] = {8'h02 , 24'b0};        
        RCi[2] = {8'h04 , 24'b0};        
        RCi[3] = {8'h08 , 24'b0};        
        RCi[4] = {8'h10 , 24'b0};        
        RCi[5] = {8'h20 , 24'b0};        
        RCi[6] = {8'h40 , 24'b0};        
        RCi[7] = {8'h80 , 24'b0};        
        RCi[8] = {8'h1b , 24'b0};        
        RCi[9] = {8'h36 , 24'b0};        


        W[0] = {key[0][0] , key[1][0] , key[2][0] , key[3][0]};
        W[1] = {key[0][1] , key[1][1] , key[2][1] , key[3][1]};
        W[2] = {key[0][2] , key[1][2] , key[2][2] , key[3][2]};
        W[3] = {key[0][3] , key[1][3] , key[2][3] , key[3][3]};

        for (i = 4; i < 44; i = i + 1) begin
            temp = W[i-1];

            if (i % 4 == 0) begin
                // RotWord
                rotTemp = {temp[23:0], temp[31:24]};

                // SubWord
                subTemp = {
                    aes_sbox(rotTemp[31:24]),
                    aes_sbox(rotTemp[23:16]),
                    aes_sbox(rotTemp[15:8]),
                    aes_sbox(rotTemp[7:0])
                };

                // XOR with Rcon
                gTemp = subTemp ^ RCi[(i/4)-1];

                W[i] = W[i-4] ^ gTemp;
            end
            else begin
                W[i] = W[i-4] ^ temp;
            end
        end

        // Pack words into 11 round keys
        for (r = 0; r < 11; r = r + 1) begin
            roundKey[r] = {
                W[4*r],
                W[4*r + 1],
                W[4*r + 2],
                W[4*r + 3]
            };
        end
    end
    
endmodule