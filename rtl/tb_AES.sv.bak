`timescale 1ns/1ps

module tb_subBytes;

    logic [7:0] arrayIn  [0:3][0:3];
    logic [7:0] arrayOut [0:3][0:3];

    // Instantiate DUT
    AES dut (
        .arrayIn(arrayIn),
        .arrayOut(arrayOut)
    );

    initial begin
        // Test input values
        arrayIn[0][0] = 8'h00;
        arrayIn[0][1] = 8'h01;
        arrayIn[0][2] = 8'h02;
        arrayIn[0][3] = 8'h03;

        arrayIn[1][0] = 8'h10;
        arrayIn[1][1] = 8'h11;
        arrayIn[1][2] = 8'h12;
        arrayIn[1][3] = 8'h13;

        arrayIn[2][0] = 8'h20;
        arrayIn[2][1] = 8'h21;
        arrayIn[2][2] = 8'h22;
        arrayIn[2][3] = 8'h23;

        arrayIn[3][0] = 8'h30;
        arrayIn[3][1] = 8'h31;
        arrayIn[3][2] = 8'h32;
        arrayIn[3][3] = 8'h33;

        #10;

        $display("Input Matrix:");
        print_matrix(arrayIn);

        $display("Output Matrix:");
        print_matrix(arrayOut);

        // Simple checks
        
        $finish;
    end

    // Task to print 4x4 matrix
    task print_matrix(input logic [7:0] matrix [0:3][0:3]);
        integer i, j;
        begin
            for (i = 0; i < 4; i = i + 1) begin
                for (j = 0; j < 4; j = j + 1) begin
                    $write("%h ", matrix[i][j]);
                end
                $write("\n");
            end
        end
    endtask

endmodule